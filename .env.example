# AgentAuditor Environment Variables

# LLM Judge — Anthropic (optional, only needed if llm_judge_enabled: true)
# ANTHROPIC_API_KEY=sk-ant-...

# LLM Judge — OpenAI (optional, only needed if llm_judge_enabled: true)
# OPENAI_API_KEY=sk-...

# Custom policy path (optional, defaults to built-in policy)
# AGENTAUDITOR_POLICY_PATH=/path/to/policy.yaml
